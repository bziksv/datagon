{
  "name": "datagon-docs",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "prestart": "node ./scripts/patch-docusaurus-progress.cjs",
    "prebuild": "node ./scripts/patch-docusaurus-progress.cjs",
    "start": "CI=true docusaurus start --port 3004",
    "build": "CI=true docusaurus build --out-dir ../public/docs",
    "serve": "docusaurus serve --dir ../public/docs --port 3005",
    "capture-screenshots": "playwright test",
    "capture-screenshots:real": "DOCS_CAPTURE_REAL_ONLY=1 playwright test",
    "capture-screenshots:install": "playwright install chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0"
  },
  "dependencies": {
    "@docusaurus/core": "3.9.2",
    "@docusaurus/preset-classic": "3.9.2",
    "@easyops-cn/docusaurus-search-local": "0.52.0"
  },
  "overrides": {
    "webpackbar": "5.0.2"
  }
}
